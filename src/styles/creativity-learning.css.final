}

/* Try It Out Sections */
.seeds-generator, .cultural-pre-question, .flat-sentence-starter {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  padding: 20px;
  margin-bottom: 20px;
}

.cultural-detail-input, .user-prompt-input {
  background: rgba(255, 255, 255, 0.1);
  border: 2px solid rgba(255, 255, 255, 0.2);
  border-radius: 10px;
  padding: 15px;
  color: white;
  font-size: 14px;
  width: 100%;
  resize: vertical;
  transition: all 0.3s ease;
  font-family: inherit;
  line-height: 1.5;
}

.cultural-detail-input:focus, .user-prompt-input:focus {
  outline: none;
  border-color: #667eea;
  background: rgba(255, 255, 255, 0.15);
  box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
}

.generate-seeds-button, .continue-button, .start-rewrite-button {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  border-radius: 12px;
  padding: 14px 24px;
  color: white;
  font-weight: 600;
  font-size: 14px;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
  position: relative;
  overflow: hidden;
}

.generate-seeds-button:hover, .continue-button:hover, .start-rewrite-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(102, 126, 234, 0.6);
  background: linear-gradient(135deg, #764ba2 0%, #667eea 100%);
}

.generate-seeds-button:active, .continue-button:active, .start-rewrite-button:active {
  transform: translateY(0);
  box-shadow: 0 2px 10px rgba(102, 126, 234, 0.4);
}

.seeds-display {
  display: flex;
  align-items: center;
  gap: 15px;
  margin: 15px 0;
  flex-wrap: wrap;
}

.seed-item {
  background: rgba(33, 150, 243, 0.2);
  padding: 10px 15px;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  gap: 5px;
}

.seed-label {
  font-size: 12px;
  color: #90CAF9;
  font-weight: 600;
}

.seed-text {
  color: #e0e0e0;
  font-style: italic;
}

.seed-connector {
  font-size: 24px;
  color: #4CAF50;
  font-weight: bold;
}

/* Banned Words System */
.word-ban-system {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  padding: 20px;
}

.banned-words {
  margin: 15px 0;
}

.word-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 10px 0;
}

.banned-word {
  background: rgba(244, 67, 54, 0.2);
  color: #f44336;
  padding: 4px 8px;
  border-radius: 15px;
  font-size: 12px;
  font-weight: 600;
}

.word-warning {
  background: rgba(255, 193, 7, 0.2);
  border: 1px solid rgba(255, 193, 7, 0.5);
  border-radius: 8px;
  padding: 10px;
  color: #FFC107;
  margin-top: 10px;
}

/* Iteration Stacking */
.iteration-stacking {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.version-container {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  padding: 20px;
  border-left: 4px solid #9C27B0;
}

.version-header {
  display: flex;
  align-items: center;
  gap: 15px;
  margin-bottom: 15px;
}

.version-number {
  background: rgba(156, 39, 176, 0.3);
  color: #9C27B0;
  padding: 5px 12px;
  border-radius: 15px;
  font-weight: 600;
  font-size: 14px;
}

.constraint-display {
  background: rgba(255, 193, 7, 0.2);
  padding: 10px 15px;
  border-radius: 8px;
  color: #FFC107;
  font-size: 14px;
  flex: 1;
}

.version-input {
  background: rgba(255, 255, 255, 0.1);
  border: 2px solid rgba(255, 255, 255, 0.2);
  border-radius: 8px;
  padding: 15px;
  color: white;
  width: 100%;
  resize: vertical;
}

.final-version {
  border-color: #4CAF50;
}

.constraint-button {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  border: none;
  border-radius: 12px;
  padding: 12px 20px;
  color: white;
  font-weight: 600;
  cursor: pointer;
  margin-top: 15px;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4px 15px rgba(240, 147, 251, 0.4);
}

.constraint-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(240, 147, 251, 0.6);
  background: linear-gradient(135deg, #f5576c 0%, #f093fb 100%);
}

.iteration-summary {
  background: rgba(76, 175, 80, 0.2);
  border-radius: 8px;
  padding: 15px;
  margin-top: 15px;
  color: #4CAF50;
}

/* Goldilocks System */
.goldilocks-system {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  padding: 20px;
}

.complexity-examples {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 25px;
}

.example-card {
  padding: 15px;
  border-radius: 10px;
  border: 2px solid;
}

.too-simple {
  background: rgba(158, 158, 158, 0.1);
  border-color: #9E9E9E;
}

.too-complex {
  background: rgba(244, 67, 54, 0.1);
  border-color: #f44336;
}

.complexity-slider-container {
  margin: 20px 0;
}

.slider-wrapper {
  display: flex;
  align-items: center;
  gap: 15px;
  margin: 15px 0;
}

.complexity-slider {
  flex: 1;
  height: 8px;
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.2);
  outline: none;
}

.slider-label {
  font-size: 14px;
  color: #ccc;
  font-weight: 600;
}

.slider-feedback {
  background: rgba(33, 150, 243, 0.2);
  border-radius: 8px;
  padding: 10px 15px;
  color: #2196F3;
  text-align: center;
  margin-bottom: 15px;
}

.goldilocks-input {
  margin-top: 15px;
}

.goldilocks-target {
  background: rgba(255, 193, 7, 0.2);
  border-radius: 8px;
  padding: 15px;
  margin-top: 15px;
  color: #FFC107;
  text-align: center;
}

/* Evolutionary Reset */
.evolutionary-reset {
  margin-top: 30px;
}

.reset-options {
  display: flex;
  gap: 15px;
  margin-bottom: 25px;
}

.evolve-button, .start-fresh-button {
  background: linear-gradient(135deg, #607D8B, #455A64);
  border: none;
  border-radius: 8px;
  padding: 12px 20px;
  color: white;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.evolve-button:hover, .start-fresh-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(96, 125, 139, 0.3);
}

.version-history {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  padding: 20px;
}

.version-history h5 {
  color: #e0e0e0;
  margin-bottom: 15px;
}

.history-items {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.history-item {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  padding: 12px;
}

.history-timestamp {
  color: #999;
  font-size: 12px;
}

.history-concept {
  color: #ccc;
  margin: 5px 0 0 0;
  font-size: 14px;
}

@media (max-width: 768px) {
  .mindset-shift {
    flex-direction: column;
  }
  
  .mindset-arrow {
    transform: rotate(90deg);
    margin: 20px 0;
  }
}
