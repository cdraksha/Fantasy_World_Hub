                                  });
                                  if (response.ok) {
                                    const data = await response.json();
                                    setIterationVersions(prev => ({
                                      ...prev,
                                      [`${principle.id}_constraint2`]: data.choices[0].message.content
                                    }));
                                  }
                                } catch (error) {
                                  console.error('Error generating constraint:', error);
                                }
                              }}
                              className="constraint-button"
                            >
                              Push it further →
                            </button>
                          )}
                        </div>
                      )}

                      {/* Version 3 */}
                      {iterationVersions[`${principle.id}_constraint2`] && (
                        <div className="version-container">
                          <div className="version-header">
                            <span className="version-number">Version 3</span>
                            <div className="constraint-display">
                              <strong>Constraint:</strong> {iterationVersions[`${principle.id}_constraint2`]}
                            </div>
                          </div>
                          <textarea
                            value={iterationVersions[`${principle.id}_v3`] || iterationVersions[`${principle.id}_v2`] || ''}
                            onChange={(e) => {
                              setIterationVersions(prev => ({
                                ...prev,
                                [`${principle.id}_v3`]: e.target.value
                              }));
                              // Set final result for evaluation
                              setUserPrompts(prev => ({
                                ...prev,
                                [principle.id]: e.target.value
                              }));
                            }}
                            placeholder="Final version addressing both constraints..."
                            className="version-input final-version"
                            rows={4}
                          />
                          {iterationVersions[`${principle.id}_v3`]?.trim() && (
                            <div className="iteration-summary">
                              <p><strong>🎯 Iteration Journey Complete!</strong></p>
                              <p>Version 1 → Version 3: You solved {iterationVersions[`${principle.id}_constraint1`] ? '1' : '0'} + {iterationVersions[`${principle.id}_constraint2`] ? '1' : '0'} real constraints. That's what iteration feels like.</p>
                            </div>
                          )}
                        </div>
                      )}
                      
                      <button 
                        onClick={() => {
                          setIterationVersions(prev => {
                            const newState = { ...prev };
                            delete newState[`${principle.id}_v1`];
                            delete newState[`${principle.id}_v2`];
                            delete newState[`${principle.id}_v3`];
                            delete newState[`${principle.id}_constraint1`];
                            delete newState[`${principle.id}_constraint2`];
                            return newState;
                          });
                          setUserPrompts(prev => ({
                            ...prev,
                            [principle.id]: ''
                          }));
                        }}
                        className="reset-iterations-button"
                      >
                        🔄 Start Over
                      </button>
                    </div>

                    <div className="prompt-actions">
                      <button 
                        onClick={() => evaluatePrompt(principle.id)}
                        disabled={!userPrompts[principle.id]?.trim() || isEvaluating[principle.id]}
                        className="evaluate-button"
                      >
                        {isEvaluating[principle.id] ? 'Evaluating...' : '📊 Evaluate'}
                      </button>
                    </div>

                    {/* Evaluation Results */}
                    {evaluationResults[principle.id] && (
                      <div className="evaluation-results">
                        <div className="score-display">
                          <span className="score-number">{evaluationResults[principle.id].score}/10</span>
                          <span className="score-label">Iteration Score</span>
                        </div>
                        <p className="feedback">{evaluationResults[principle.id].feedback}</p>

                        {evaluationResults[principle.id].score < 10 && (
                          <button 
                            onClick={() => refinePrompt(principle.id)}
                            disabled={isRefining[principle.id]}
                            className="refine-button"
                          >
                            {isRefining[principle.id] ? 'Refining...' : '✨ Refine to 10/10'}
                          </button>
                        )}

                        {evaluationResults[principle.id].refinedPrompt && (
                          <div className="before-after">
                            <div className="before">
                              <strong>Before:</strong> {evaluationResults[principle.id].originalPrompt}
                            </div>
                            <div className="after">
                              <strong>After (10/10):</strong> {evaluationResults[principle.id].refinedPrompt}
                            </div>
                          </div>
                        )}
                      </div>
                    )}
                  </div>
                </>
              )}

              {index === 4 && (
                <>
                  <p><strong>Great creative work finds the perfect balance of complexity:</strong></p>
                  <ul>
                    <li>Complex enough to engage and intrigue the audience</li>
                    <li>Simple enough to be accessible and understandable</li>
                    <li>Specific enough to feel authentic and real</li>
                    <li>Universal enough to connect with diverse people</li>
                  </ul>
                  <p className="fun-fact"><strong>Fun Fact:</strong> Apple's iPhone interface has thousands of complex functions hidden behind simple, intuitive gestures - sophisticated enough for power users, simple enough for grandparents.</p>
                  <div className="pattern-box"><strong>Pattern:</strong> Creativity thrives in the sweet spot between simple and complex</div>

                  {/* Try It Out Section */}
                  <div className="try-it-out-section">
                    <h4>🎯 Try it out!</h4>
                    
                    <div className="goldilocks-system">
                      <div className="complexity-examples">
                        <div className="example-card too-simple">
                          <h5>😴 Too Simple</h5>
                          <p>"Just ignore it and move on."</p>
                          <small>One line, nothing surprising, immediately forgettable</small>
                        </div>
                        
                        <div className="example-card too-complex">
                          <h5>🤯 Too Complex</h5>
                          <p>"Genetically engineer silk worms to produce fabric that changes color based on the wearer's emotional state while simultaneously launching a startup that uses AI to predict optimal solutions based on astrological charts and family WhatsApp group sentiment analysis integrated with quantum computing and blockchain verification systems."</p>
                          <small>Impressive on paper, exhausting in person</small>
                        </div>
                      </div>
                      
                      <div className="complexity-slider-container">
                        <label>Where should your idea live?</label>
                        <div className="slider-wrapper">
                          <span className="slider-label">Simple</span>
                          <input
                            type="range"
                            min="0"
                            max="100"
                            value={goldilocksSetting[principle.id] || 50}
                            onChange={(e) => {
                              const value = parseInt(e.target.value);
                              setGoldilocksSetting(prev => ({
                                ...prev,
                                [principle.id]: value
                              }));
                            }}
                            className="complexity-slider"
                          />
                          <span className="slider-label">Complex</span>
                        </div>
                        <div className="slider-feedback">
                          {goldilocksSetting[principle.id] <= 30 && (
                            <p>📝 Write it so a 5-year-old would try it</p>
                          )}
                          {goldilocksSetting[principle.id] > 30 && goldilocksSetting[principle.id] < 70 && (
                            <p>🎯 Write it so both a 5-year-old and NASA engineers argue about it</p>
                          )}
                          {goldilocksSetting[principle.id] >= 70 && (
                            <p>🧠 Write it so NASA engineers would be impressed</p>
                          )}
                        </div>
                      </div>

                      <textarea
                        value={userPrompts[principle.id] || ''}
                        onChange={(e) => setUserPrompts(prev => ({
                          ...prev,
                          [principle.id]: e.target.value
                        }))}
                        placeholder={
                          goldilocksSetting[principle.id] <= 30 
                            ? "Write it so a 5-year-old would try it..."
                            : goldilocksSetting[principle.id] >= 70
                            ? "Write it so NASA engineers would be impressed..."
                            : "Write it so both a 5-year-old and NASA engineers argue about it..."
                        }
                        className="user-prompt-input goldilocks-input"
                        rows={4}
                      />
                      
                      <div className="goldilocks-target">
                        <p><strong>🎪 The Goldilocks Target:</strong> "So both of them argue about it" - complexity that creates productive tension.</p>
                      </div>
                    </div>

                    <div className="prompt-actions">
                      <button 
                        onClick={() => evaluatePrompt(principle.id)}
                        disabled={!userPrompts[principle.id]?.trim() || isEvaluating[principle.id]}
                        className="evaluate-button"
                      >
                        {isEvaluating[principle.id] ? 'Evaluating...' : '📊 Evaluate'}
                      </button>
                    </div>

                    {/* Evaluation Results */}
                    {evaluationResults[principle.id] && (
                      <div className="evaluation-results">
                        <div className="score-display">
                          <span className="score-number">{evaluationResults[principle.id].score}/10</span>
                          <span className="score-label">Balance Score</span>
                        </div>
                        <p className="feedback">{evaluationResults[principle.id].feedback}</p>

                        {evaluationResults[principle.id].score < 10 && (
                          <button 
                            onClick={() => refinePrompt(principle.id)}
                            disabled={isRefining[principle.id]}
                            className="refine-button"
                          >
                            {isRefining[principle.id] ? 'Refining...' : '✨ Refine to 10/10'}
                          </button>
                        )}

                        {evaluationResults[principle.id].refinedPrompt && (
                          <div className="before-after">
                            <div className="before">
                              <strong>Before:</strong> {evaluationResults[principle.id].originalPrompt}
                            </div>
                            <div className="after">
                              <strong>After (10/10):</strong> {evaluationResults[principle.id].refinedPrompt}
                            </div>
                          </div>
                        )}
                      </div>
                    )}
                  </div>
                </>
              )}
            </div>
            {/* Generation side */}
            <div className="principle-generation">
              {renderGenerationBox(principle)}
            </div>

          </div>
        ))}
      </div>
      {/* Master Creativity Challenge */}
      <div className="master-creativity-challenge">
        <h2>🎨 Master Creativity Challenge</h2>
        <p>Ready for the Real Test? Describe any creative concept and we'll evaluate it using all 5 creativity principles!</p>

        <div className="master-challenge-form">

          {!masterConcept ? (
            <div className="two-field-input">
              <div className="input-field">
                <label>What's your current situation?</label>
                <textarea
                  value={masterSituation}
                  onChange={(e) => setMasterSituation(e.target.value)}
                  placeholder="describe something that's annoying you right now..."
                  className="situation-input"
                  rows={2}
                />
              </div>
              
              <div className="input-field">
                <label>What impossible thing would make this better?</label>
                <textarea
                  value={masterWish}
                  onChange={(e) => setMasterWish(e.target.value)}
                  placeholder={`what would make "${userContext}" disappear if physics didn't matter...`}
                  className="wish-input"
                  rows={2}
                />
              </div>
              
              <button 
                onClick={combineMasterInputs}
                disabled={!masterSituation.trim() || !masterWish.trim()}
                className="combine-button"
              >
                Combine These →
              </button>
            </div>
          ) : (
            <div className="combined-concept">
              <label>Your Creative Concept:</label>
              <textarea
                value={masterConcept}
                onChange={(e) => setMasterConcept(e.target.value)}
                className="master-concept-input"
                rows={6}
              />
              <button 
                onClick={() => {
                  setMasterConcept('');
                  setMasterSituation('');
                  setMasterWish('');
                  setMasterProvocation('');
                }}
                className="edit-inputs-button"
              >
                ← Edit Inputs
              </button>
            </div>
          )}

          {/* AI Provocation - The Self-Interrogation Beat */}
          {masterConcept && (
            <div className="master-provocation">
              {isGeneratingProvocation ? (
                <div className="provocation-loading">
                  <span className="loading-dots">Thinking...</span>
                </div>
              ) : masterProvocation ? (
                <div className="provocation-text">
                  <p>{masterProvocation}</p>
                </div>
              ) : null}
            </div>
          )}

          <button 
            onClick={evaluateMasterConcept}
            disabled={!masterConcept.trim() || isMasterEvaluating || isGeneratingProvocation || !masterProvocation}
            className="master-evaluate-button"
          >
            {isMasterEvaluating ? 'Evaluating...' : isGeneratingProvocation ? 'Preparing...' : masterProvocation ? 'I\'m ready — evaluate this →' : '🧠 Evaluate My Creativity'}
          </button>
        </div>
        {/* Comprehensive Evaluation Results */}
        {masterEvaluation && (
          <div className="master-evaluation-results">
            <h3>📊 Comprehensive Creativity Evaluation</h3>

            <div className="narrative-feedback">
              <div className="principle-feedback">
                <div className="principle-header">
                  <span className="principle-icon">🔗</span>
                  <span className="principle-title">Adjacent Possible</span>
                  <span className="principle-score">{masterEvaluation.adjacentPossible?.score || masterEvaluation.adjacentPossible}/10</span>
                </div>
                <p className="narrative-text">
                  {masterEvaluation.adjacentPossible?.narrative || `Score: ${masterEvaluation.adjacentPossible}/10`}
                </p>
              </div>

              <div className="principle-feedback">
                <div className="principle-header">
                  <span className="principle-icon">🇮🇳</span>
                  <span className="principle-title">Cultural Specificity</span>
                  <span className="principle-score">{masterEvaluation.culturalSpecificity?.score || masterEvaluation.culturalSpecificity}/10</span>
                </div>
                <p className="narrative-text">
                  {masterEvaluation.culturalSpecificity?.narrative || `Score: ${masterEvaluation.culturalSpecificity}/10`}
                </p>
              </div>

              <div className="principle-feedback">
                <div className="principle-header">
                  <span className="principle-icon">🎭</span>
                  <span className="principle-title">Show Don't Tell</span>
                  <span className="principle-score">{masterEvaluation.showDontTell?.score || masterEvaluation.showDontTell}/10</span>
                </div>
                <p className="narrative-text">
                  {masterEvaluation.showDontTell?.narrative || `Score: ${masterEvaluation.showDontTell}/10`}
                </p>
              </div>

              <div className="principle-feedback">
                <div className="principle-header">
                  <span className="principle-icon">🔄</span>
                  <span className="principle-title">Iteration Instinct</span>
                  <span className="principle-score">{masterEvaluation.iterationInstinct?.score || masterEvaluation.iterationInstinct}/10</span>
                </div>
                <p className="narrative-text">
                  {masterEvaluation.iterationInstinct?.narrative || `Score: ${masterEvaluation.iterationInstinct}/10`}
                </p>
              </div>

              <div className="principle-feedback">
                <div className="principle-header">
                  <span className="principle-icon">⚖️</span>
                  <span className="principle-title">Goldilocks Balance</span>
                  <span className="principle-score">{masterEvaluation.goldilocks?.score || masterEvaluation.goldilocks}/10</span>
                </div>
                <p className="narrative-text">
                  {masterEvaluation.goldilocks?.narrative || `Score: ${masterEvaluation.goldilocks}/10`}
                </p>
              </div>
            </div>

            <div className="overall-score">
              <span className="overall-label">Overall Creativity Score:</span>
              <span className="overall-number">{masterEvaluation.overall}/10</span>
            </div>

            <p className="master-feedback">{masterEvaluation.feedback}</p>

            {masterEvaluation.overall < 9 && (
              <div className="three-unlocks-system">
                {!masterUnlockQuestions ? (
                  <button 
                    onClick={generateUnlockQuestions}
                    className="unlock-questions-button"
                  >
                    🔓 Unlock Your Potential
                  </button>
                ) : (
                  <div className="unlock-questions">
                    <h4>🔓 The Three Unlocks</h4>
                    <p>Answer these questions to unlock your concept's potential:</p>
                    
                    {masterUnlockQuestions.map((question, index) => (
                      <div key={question.principle} className="unlock-question">
                        <div className="question-header">
                          <span className="question-icon">{question.icon}</span>
                          <span className="question-principle">{question.name}</span>
                        </div>
                        <p className="question-text">{question.question}</p>
                        <textarea
                          value={masterUnlockAnswers[question.principle] || ''}
                          onChange={(e) => setMasterUnlockAnswers(prev => ({
                            ...prev,
                            [question.principle]: e.target.value
                          }))}
                          placeholder="Your answer..."
                          className="unlock-answer-input"
                          rows={3}
                        />
                      </div>
                    ))}
                    
                    <button 
                      onClick={refineMasterConcept}
                      disabled={isMasterRefining || Object.keys(masterUnlockAnswers).length < 2}
                      className="master-refine-button"
                    >
                      {isMasterRefining ? 'Refining...' : '✨ Refine Using My Answers'}
                    </button>
                  </div>
                )}
              </div>
            )}

            {masterEvaluation.refinedConcept && (
              <div className="master-before-after">
                <div className="master-before">
                  <strong>Before:</strong> {masterEvaluation.originalConcept}
                </div>
                <div className="master-after">
                  <strong>After (Master Level):</strong> {masterEvaluation.refinedConcept}
                </div>
              </div>
            )}

            <div className="format-selection">
              <label>How would you like to express this idea?</label>
              <select 
                value={masterFormat} 
                onChange={(e) => setMasterFormat(e.target.value)}
                className="format-dropdown"
              >
                <option value="text-only">📝 Text Only</option>
                <option value="text-image">📝🖼️ Text + Image</option>
                <option value="image-only">🖼️ Image Only</option>
                <option value="image-video">🎬 Image → Video (115s)</option>
              </select>
            </div>

            <button 
              onClick={generateMasterContent}
              disabled={isMasterGenerating}
              className="master-create-button"
            >
              {isMasterGenerating ? 'Creating...' : '🎬 Create This Experience'}
            </button>
          </div>
        )}
        {/* Generated Content Display */}
        {masterGeneratedContent && (
          <div className="master-generated-content">
            <h3>✨ Your Master Creation</h3>

            {/* Water Cooler Version First - The Litmus Test */}
            {masterGeneratedContent.text && typeof masterGeneratedContent.text === 'object' && masterGeneratedContent.text.waterCoolerVersion && (
              <div className="whatsapp-test-first">
                <div className="water-cooler-version">
                  <h5>💬 The Water Cooler Version:</h5>
                  <p className="water-cooler-text">"{masterGeneratedContent.text.waterCoolerVersion}"</p>
                  <small>If you can say this out loud without cringing, it's ready to share.</small>
                </div>
                
                {masterGeneratedContent.text.whatThisIsNot && (
                  <div className="what-this-is-not">
                    <h5>🚫 What This Is NOT:</h5>
                    <p className="rejection-text">{masterGeneratedContent.text.whatThisIsNot}</p>
                  </div>
                )}
              </div>
            )}

            {masterGeneratedContent.text && (
              <div className="master-generated-text">
                <h4>📝 Generated Content:</h4>
                <p>{typeof masterGeneratedContent.text === 'object' ? masterGeneratedContent.text.content : masterGeneratedContent.text}</p>
              </div>
            )}

            {masterGeneratedContent.image && (
              <div className="master-generated-image">
                <h4>🖼️ Generated Visual:</h4>
                <img src={masterGeneratedContent.image.url} alt="Master creation" />
              </div>
            )}

            {masterGeneratedContent.video && (
              <div className="master-generated-video">
                <h4>🎬 Generated Video:</h4>
                <video src={masterGeneratedContent.video.url} controls />
              </div>
            )}

            <div className="master-actions">
              <div className="evolutionary-reset">
                <div className="reset-options">
                  <button 
                    onClick={() => {
                      // Add current concept to version history
                      const currentVersion = {
                        concept: masterConcept,
                        evaluation: masterEvaluation,
                        generatedContent: masterGeneratedContent,
                        timestamp: new Date().toLocaleString()
                      };
                      setMasterVersionHistory(prev => [...prev, currentVersion]);
                      
                      // Show evolution input
                      setMasterConcept('');
                      setMasterEvaluation(null);
                      setMasterGeneratedContent(null);
                      setMasterUnlockQuestions(null);
                      setMasterUnlockAnswers({});
                    }}
                    className="evolve-button"
                  >
                    Evolve This →
                  </button>
                  
                  <button 
                    onClick={() => {
                      // Add current concept to version history
                      const currentVersion = {
                        concept: masterConcept,
                        evaluation: masterEvaluation,
                        generatedContent: masterGeneratedContent,
                        timestamp: new Date().toLocaleString()
                      };
                      setMasterVersionHistory(prev => [...prev, currentVersion]);
                      
                      // Complete reset
                      setMasterConcept('');
                      setMasterSituation('');
                      setMasterWish('');
                      setMasterEvaluation(null);
                      setMasterGeneratedContent(null);
                      setMasterUnlockQuestions(null);
                      setMasterUnlockAnswers({});
                    }}
                    className="start-fresh-button"
                  >
                    Start Fresh →
                  </button>
                </div>
                
                {masterVersionHistory.length > 0 && (
                  <div className="version-history">
                    <h5>Previous Attempts:</h5>
                    <div className="history-items">
                      {masterVersionHistory.slice(-3).map((version, index) => (
                        <div key={index} className="history-item">
                          <small className="history-timestamp">{version.timestamp}</small>
                          <p className="history-concept">{version.concept.substring(0, 100)}...</p>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </div>
          </div>
        )}
      </div>
      <div className="creativity-footer">
        <button className="return-button" onClick={onReturn}>
          Return to FantasyWorld Hub
        </button>
      </div>
    </div>
  );
};
export default CreativityLearningPage;