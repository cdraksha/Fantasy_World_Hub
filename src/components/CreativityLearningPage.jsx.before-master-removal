  const generateMasterContent = async () => {
    const conceptToUse = masterEvaluation?.refinedConcept || masterConcept;
    if (!conceptToUse.trim()) return;
    setIsMasterGenerating(true);
    try {
      let generatedText = null;
      let generatedImage = null;
      let generatedVideo = null;
