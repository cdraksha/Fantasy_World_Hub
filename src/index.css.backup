* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
  overflow-x: hidden;
  overflow-y: auto;
  color: #e0e6ed;
  line-height: 1.6;
}

#root {
  width: 100vw;
  min-height: 100vh;
  overflow-y: auto;
}

/* Creative Reminder Banner */
.creative-reminder-banner {
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.1), rgba(255, 193, 7, 0.1));
  border: 1px solid rgba(255, 193, 7, 0.3);
  border-radius: 10px;
  padding: 20px;
  margin-bottom: 40px;
  text-align: center;
  backdrop-filter: blur(5px);
}

.creative-reminder-banner p {
  color: #ffcc80;
  font-size: 1.1rem;
  line-height: 1.6;
  margin: 0 0 1rem 0;
  font-style: italic;
}

.vision-section {
  margin: 40px 0;
  text-align: center;
}

.vision-heading {
  font-size: 2rem;
  color: #ffcc80;
  margin-bottom: 20px;
  font-weight: 600;
  text-shadow: 0 2px 10px rgba(255, 204, 128, 0.3);
}

.hub-actions {
  display: flex;
  gap: 15px;
  justify-content: center;
  flex-wrap: wrap;
  margin: 40px 0;
}

.experience-hub-section {
  margin-top: 60px;
  padding: 40px 20px;
  background: 
    linear-gradient(135deg, rgba(139, 69, 19, 0.05), rgba(255, 193, 7, 0.05)),
    radial-gradient(circle at center, rgba(255, 204, 128, 0.03) 0%, transparent 70%);
  border: 1px solid rgba(255, 193, 7, 0.15);
  border-top: none;
  border-radius: 0;
  backdrop-filter: blur(5px);
  box-shadow: 
    0 10px 30px rgba(0, 0, 0, 0.1),
    inset 0 1px 0 rgba(255, 255, 255, 0.05);
  position: relative;
}

.experience-hub-section::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(45deg, transparent 30%, rgba(255, 204, 128, 0.02) 50%, transparent 70%);
  border-radius: 0;
  animation: sectionShimmer 6s ease-in-out infinite;
  pointer-events: none;
}

@keyframes sectionShimmer {
  0% { opacity: 0.3; }
  50% { opacity: 0.6; }
  100% { opacity: 0.3; }
}

.experience-hub-heading {
  font-size: 3rem;
  background: linear-gradient(45deg, #ffcc80, #ffd700, #ff6b6b, #667eea, #feca57);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-align: center;
  margin-bottom: 50px;
  font-weight: 700;
  text-shadow: 0 0 30px rgba(255, 204, 128, 0.6);
  animation: hubHeadingGlow 3s ease-in-out infinite alternate;
  letter-spacing: 2px;
  position: relative;
}

.experience-hub-heading::after {
  content: '';
  position: absolute;
  bottom: -20px;
  left: 50%;
  transform: translateX(-50%);
  width: 200px;
  height: 3px;
  background: linear-gradient(45deg, #ffcc80, #ffd700, #ff6b6b);
  border-radius: 2px;
  box-shadow: 0 0 20px rgba(255, 204, 128, 0.5);
}

@keyframes hubHeadingGlow {
  0% { 
    text-shadow: 0 0 30px rgba(255, 204, 128, 0.6), 0 0 60px rgba(255, 215, 0, 0.3);
    transform: scale(1);
  }
  100% { 
    text-shadow: 0 0 40px rgba(255, 215, 0, 0.8), 0 0 80px rgba(255, 107, 107, 0.4);
    transform: scale(1.02);
  }
}

.about-button, .vision-button {
  color: white;
  border: none;
  padding: 0.8rem 1.5rem;
  border-radius: 6px;
  font-size: 0.9rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
}

.about-button {
  background: linear-gradient(135deg, #64b5f6 0%, #42a5f5 100%);
}

.about-button:hover {
  background: linear-gradient(135deg, #42a5f5 0%, #1e88e5 100%);
  transform: translateY(-1px);
}

.vision-button {
  background: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%);
}

.vision-button:hover {
  background: linear-gradient(135deg, #feca57 0%, #ff9ff3 100%);
  transform: translateY(-1px);
}

.inspired-by-tag {
  font-size: 0.75rem;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.1);
  padding: 0.3rem 0.6rem;
  border-radius: 12px;
  text-align: center;
  margin-top: 0.8rem;
  font-style: italic;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.survey-link {
  margin-top: 15px;
  padding-top: 15px;
  border-top: 1px solid rgba(255, 193, 7, 0.2);
}

.survey-link p {
  color: #fff;
  font-size: 1rem;
  font-style: normal;
}

.survey-link a {
  color: #ffc107;
  text-decoration: underline;
  font-weight: 500;
  transition: color 0.3s ease;
}

.survey-link a:hover {
  color: #fff;
}

@keyframes gentlePulse {
  0%, 100% { opacity: 0.9; }
  50% { opacity: 1; }
}

/* Hub Landing Styles */
.hub-landing {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  color: #fff;
  font-family: 'Inter', 'Arial', sans-serif;
  position: relative;
  overflow-x: hidden;
  overflow-y: scroll;
  padding: 20px 15px 100px 15px;
}

.stars-background {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: 
    radial-gradient(2px 2px at 20px 30px, #ffffff, transparent),
    radial-gradient(2px 2px at 40px 70px, rgba(255,255,255,0.8), transparent),
    radial-gradient(1px 1px at 90px 40px, rgba(255,255,255,0.6), transparent),
    radial-gradient(1px 1px at 130px 80px, rgba(255,255,255,0.4), transparent),
    radial-gradient(2px 2px at 160px 30px, rgba(255,255,255,0.7), transparent);
  background-repeat: repeat;
  background-size: 200px 100px;
  animation: twinkle 20s linear infinite;
  z-index: 0;
}

@keyframes twinkle {
  0% { transform: translateY(0); }
  100% { transform: translateY(-100px); }
}

.hub-content {
  text-align: center;
  z-index: 2;
  position: relative;
  max-width: 1200px;
  width: 100%;
  margin: 0 auto;
  padding: 20px 0;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 25px;
  backdrop-filter: blur(15px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
}

.hub-title {
  font-size: 4rem;
  font-weight: bold;
  text-align: center;
  margin-bottom: 20px;
  background: linear-gradient(45deg, #fff, #ffc107, #ff9800);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 0 30px rgba(255, 193, 7, 0.5);
  letter-spacing: 3px;
}

.hub-subtitle {
  font-size: 1.3rem;
  margin-bottom: 50px;
  color: #b0bec5;
  font-weight: 300;
  font-style: italic;
}

/* Mobile Responsive Styles */
@media (max-width: 768px) {
  .hub-landing {
    padding: 15px 10px 80px 10px;
  }
  
  .hub-title {
    font-size: 2.5rem;
  }
  
  .hub-subtitle {
    font-size: 1rem;
    margin-bottom: 25px;
  }
  
  .creative-reminder-banner {
    padding: 15px;
    margin-bottom: 30px;
  }
  
  .creative-reminder-banner p {
    font-size: 1rem;
    line-height: 1.5;
  }
  
  .survey-link p {
    font-size: 0.9rem;
  }
}

.space-cafe-button {
  background: linear-gradient(45deg, #1e3c72, #2a5298);
  border: none;
  padding: 18px 40px;
  font-size: 1.4rem;
  color: white;
  border-radius: 50px;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 8px 25px rgba(30, 60, 114, 0.3);
  font-weight: 500;
  letter-spacing: 1px;
}

.space-cafe-button:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 35px rgba(30, 60, 114, 0.4);
  background: linear-gradient(45deg, #2a5298, #1e3c72);
}

.learn-more-btn {
  position: relative;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  border: none;
  padding: 20px 35px;
  border-radius: 20px;
  font-size: 1rem;
  color: white;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: 
    0 8px 25px rgba(102, 126, 234, 0.4),
    0 0 30px rgba(118, 75, 162, 0.2),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  min-width: 280px;
}

.learn-more-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.6s ease;
}

.learn-more-btn:hover::before {
  left: 100%;
}

.learn-more-btn:hover {
  transform: translateY(-4px) scale(1.05);
  box-shadow: 
    0 15px 35px rgba(102, 126, 234, 0.6),
    0 0 50px rgba(118, 75, 162, 0.4),
    0 0 70px rgba(240, 147, 251, 0.3);
}

.btn-icon {
  font-size: 1.4rem;
  margin-bottom: 2px;
}

.btn-text {
  font-weight: 700;
  font-size: 1.1rem;
  letter-spacing: 0.5px;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
}

.btn-subtitle {
  font-size: 0.85rem;
  opacity: 0.9;
  font-weight: 400;
  letter-spacing: 0.3px;
}

/* Creativity Button Styles */
.creativity-btn {
  position: relative;
  background: linear-gradient(135deg, #ff9a56 0%, #ffad56 50%, #ffc947 100%);
  border: none;
  border-radius: 20px;
  padding: 20px 40px;
  color: #2c1810;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  font-family: 'Inter', sans-serif;
  text-decoration: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  box-shadow: 
    0 8px 25px rgba(255, 154, 86, 0.4),
    0 0 30px rgba(255, 173, 86, 0.2);
  overflow: hidden;
  margin: 20px auto;
  min-width: 280px;
}

.creativity-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.6s ease;
}

.creativity-btn:hover::before {
  left: 100%;
}

.creativity-btn:hover {
  transform: translateY(-4px) scale(1.05);
  box-shadow: 
    0 15px 35px rgba(255, 154, 86, 0.6),
    0 0 50px rgba(255, 173, 86, 0.4),
    0 0 70px rgba(255, 201, 71, 0.3);
}

/* Experiences Grid */
.experiences-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Mobile responsive - single column on small screens */
@media (max-width: 768px) {
  .experiences-grid {
    grid-template-columns: 1fr;
    gap: 20px;
    padding: 0 15px;
  }
}

/* Tablet responsive - two columns on medium screens */
@media (min-width: 769px) and (max-width: 1024px) {
  .experiences-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 25px;
  }
}

/* Category Section */
.category-section {
  margin-bottom: 60px;
  gap: 30px;
  grid-column: 1 / -1;
}

@media (max-width: 768px) {
  .experience-row {
    grid-template-columns: 1fr;
    gap: 20px;
    padding: 0 10px;
  }
  
  .experience-card {
    padding: 20px;
    margin-bottom: 15px;
  }
  
  .experience-title {
    font-size: 1.3rem;
  }
  
  .experience-description {
    font-size: 0.9rem;
    line-height: 1.4;
  }
  
  .experience-button {
    padding: 12px 24px;
    font-size: 1rem;
    width: 100%;
    max-width: 250px;
  }
  
  .content-type-banner {
    font-size: 0.7rem;
    padding: 4px 8px;
  }
  
  .experience-icon {
    font-size: 2rem;
  }
}

.experience-card {
  background: linear-gradient(135deg, 
    rgba(15, 23, 42, 0.95) 0%,
    rgba(30, 41, 59, 0.9) 50%,
    rgba(51, 65, 85, 0.85) 100%);
  border: 2px solid transparent;
  background-clip: padding-box;
  border-radius: 25px;
  padding: 25px;
  transition: all 0.3s ease;
  backdrop-filter: blur(20px);
  position: relative;
  overflow: visible;
  box-shadow: 
    0 15px 40px rgba(0, 0, 0, 0.4),
    0 5px 15px rgba(0, 0, 0, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.1),
    0 0 0 1px rgba(255, 204, 128, 0.2);
  display: flex;
  flex-direction: column;
  height: 580px;
  cursor: pointer;
}

.experience-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, 
    rgba(255, 204, 128, 0.1) 0%,
    rgba(255, 215, 0, 0.05) 50%,
    rgba(255, 107, 107, 0.1) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.card-header {
  position: absolute;
  top: 10px;
  left: 10px;
  right: 10px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 2;
  gap: 10px;
}

.card-header-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.content-type-banner {
  background: rgba(220, 38, 127, 0.9);
  color: #fff;
  font-size: 0.7rem;
  font-weight: bold;
  padding: 4px 8px;
  text-align: center;
  border: 1px solid rgba(220, 38, 127, 0.8);
  backdrop-filter: blur(5px);
  border-radius: 12px;
  box-shadow: 0 2px 8px rgba(220, 38, 127, 0.3);
}

.info-button {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(100, 149, 237, 0.8);
  border: 2px solid rgba(255, 255, 255, 0.3);
  color: white;
  font-size: 12px;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
}

.info-button:hover {
  background: rgba(100, 149, 237, 1);
  transform: scale(1.1);
  box-shadow: 0 4px 15px rgba(100, 149, 237, 0.4);
}

.experience-card.available {
  border-color: rgba(100, 181, 246, 0.3);
  box-shadow: 0 8px 32px rgba(100, 181, 246, 0.1);
}

.experience-card.available:hover {
  transform: translateY(-12px) scale(1.03);
  box-shadow: 
    0 30px 60px rgba(0, 0, 0, 0.5),
    0 15px 30px rgba(0, 0, 0, 0.3),
    0 0 40px rgba(255, 204, 128, 0.4),
    0 0 80px rgba(255, 215, 0, 0.2),
    inset 0 1px 0 rgba(255, 255, 255, 0.2),
    0 0 0 2px rgba(255, 204, 128, 0.5);
}

.experience-card.available:hover::before {
  opacity: 1;
}

.experience-card.coming-soon {
  opacity: 0.6;
  border-color: rgba(255, 255, 255, 0.05);
}

.experience-icon {
  font-size: 4rem;
  margin-bottom: 20px;
  display: block;
}

.experience-title {
  font-size: 1.5rem;
  font-weight: 400;
  margin-bottom: 15px;
  color: #e0e6ed;
}

.card-description {
  color: #e2e8f0;
  font-size: 0.85rem;
  line-height: 1.4;
  margin: 0;
  text-align: center;
  height: 100px;
  display: block;
  padding: 150px 10px 40px 10px;
  overflow: visible;
}

.card-center-section {
  display: flex;
  justify-content: center;
  margin: auto 0 30px 0;
}

.enter-btn {
  background: linear-gradient(135deg, #ffcc80 0%, #ffd700 50%, #ff6b6b 100%);
  background-size: 200% 200%;
  border: none;
  padding: 12px 28px;
  color: white;
  border-radius: 25px;
  cursor: pointer;
  font-size: 1rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: 
    0 8px 25px rgba(255, 204, 128, 0.4),
    0 0 30px rgba(255, 215, 0, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.2);
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  animation: buttonPulse 4s ease-in-out infinite alternate;
  position: relative;
  overflow: hidden;
}

.enter-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
  transition: left 0.6s ease;
}

.enter-btn:hover::before {
  left: 100%;
}

.enter-btn:hover {
  background-position: 100% 100%;
  transform: translateY(-3px) scale(1.05);
  box-shadow: 
    0 15px 40px rgba(255, 204, 128, 0.6),
    0 0 50px rgba(255, 215, 0, 0.5),
    0 0 80px rgba(255, 107, 107, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.3);
  animation-duration: 1.5s;
}

@keyframes buttonPulse {
  0% { 
    box-shadow: 
      0 8px 25px rgba(255, 204, 128, 0.4),
      0 0 30px rgba(255, 215, 0, 0.3);
  }
  100% { 
    box-shadow: 
      0 12px 35px rgba(255, 204, 128, 0.6),
      0 0 50px rgba(255, 215, 0, 0.5);
  }
}

.experience-button.disabled {
  background: rgba(255, 255, 255, 0.1);
  color: #90a4ae;
  cursor: not-allowed;
  box-shadow: none;
}

/* Coming Soon Card Styles */
.experience-card.coming-soon {
  opacity: 0.7;
  position: relative;
  cursor: default;
}

.experience-card.coming-soon:hover {
  transform: none;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
}

.coming-soon-badge {
  position: absolute;
  top: 15px;
  right: 15px;
  background: linear-gradient(45deg, #ff6b6b, #ee5a24);
  color: white;
  padding: 8px 15px;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: bold;
  box-shadow: 0 4px 15px rgba(255, 107, 107, 0.3);
}

.inspiration-note {
  position: absolute;
  bottom: 15px;
  right: 15px;
  background: rgba(0, 0, 0, 0.6);
  color: #ccc;
  padding: 4px 8px;
  border-radius: 8px;
  font-size: 0.7rem;
  font-style: italic;
  backdrop-filter: blur(5px);
}

.inspiration-note a {
  color: #4fc3f7;
  text-decoration: none;
  font-weight: bold;
}

.inspiration-note a:hover {
  color: #81d4fa;
  text-decoration: underline;
}

.creation-timestamp {
  background: rgba(0, 0, 0, 0.6);
  color: #999;
  padding: 4px 8px;
  border-radius: 8px;
  font-size: 0.7rem;
  font-style: italic;
  backdrop-filter: blur(5px);
}

.experience-card.coming-soon .experience-icon {
  opacity: 0.6;
}

.experience-card.coming-soon .experience-title {
  color: #b0bec5;
}

.experience-card.coming-soon .experience-description {
  color: #78909c;
}

.quick-tutorial {
  text-align: center;
  margin: 30px auto 40px;
  max-width: 600px;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 15px;
  padding: 25px;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.quick-tutorial h3 {
  margin: 0 0 20px 0;
  font-size: 1.3rem;
  color: #ffd700;
}

.tutorial-steps {
  display: flex;
  justify-content: space-around;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
}

.tutorial-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 150px;
}

.step-number {
  width: 35px;
  height: 35px;
  background: linear-gradient(45deg, #667eea, #764ba2);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  font-size: 1.1rem;
}

.step-text {
  font-size: 0.95rem;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
  line-height: 1.3;
}

@media (max-width: 768px) {
  .tutorial-steps {
    flex-direction: column;
    gap: 15px;
  }
  
  .tutorial-step {
    flex-direction: row;
    min-width: auto;
    gap: 15px;
  }
  
  .step-text {
    text-align: left;
  }
}

.hub-footer {
  margin-top: 40px;
  font-size: 1rem;
  color: #90a4ae;
  font-style: italic;
}

/* Observer Interface Styles */
.observer.hub-landing {
  min-height: 100vh;
  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
  color: #e0e6ed;
  font-family: 'Arial', sans-serif;
  position: relative;
  overflow-x: hidden;
  overflow-y: auto;
  padding-bottom: 100px;
}

.observer-container {
  height: 100vh;
  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);
  padding: 15px;
  display: flex;
  flex-direction: column;
  gap: 15px;
  overflow: hidden;
}

.observer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 20px;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 15px;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  flex-shrink: 0;
}

.header-controls {
  display: flex;
  gap: 15px;
  align-items: center;
}

.music-controls {
  display: flex;
  align-items: center;
}

.music-button {
  background: linear-gradient(45deg, #4a148c, #7b1fa2);
  border: none;
  padding: 8px 16px;
  color: white;
  border-radius: 20px;
  cursor: pointer;
  font-size: 0.9rem;
  font-weight: 500;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(74, 20, 140, 0.3);
  display: flex;
  align-items: center;
  gap: 5px;
}

.music-button:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(74, 20, 140, 0.4);
}

.music-button.generating {
  background: linear-gradient(45deg, #ff9800, #f57c00);
  animation: pulse 2s infinite;
  cursor: not-allowed;
}

.music-button.muted {
  background: linear-gradient(45deg, #757575, #424242);
  box-shadow: 0 4px 15px rgba(117, 117, 117, 0.3);
}

.music-button.playing {
  background: linear-gradient(45deg, #2e7d32, #388e3c);
  box-shadow: 0 4px 15px rgba(46, 125, 50, 0.3);
}

.music-button.disabled {
  background: linear-gradient(45deg, #424242, #616161);
  color: #9e9e9e;
  cursor: not-allowed;
  box-shadow: 0 4px 15px rgba(66, 66, 66, 0.2);
}

.observer-title {
  font-size: 1.8rem;
  font-weight: 300;
  color: #e0e6ed;
  margin: 0;
}

.stop-button {
  background: linear-gradient(45deg, #d32f2f, #f44336);
  border: none;
  padding: 12px 24px;
  color: white;
  border-radius: 25px;
  cursor: pointer;
  font-size: 1rem;
  font-weight: 500;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(211, 47, 47, 0.3);
}

.stop-button:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(211, 47, 47, 0.4);
}

.next-button {
  background: linear-gradient(45deg, #1976d2, #42a5f5);
  border: none;
  padding: 12px 24px;
  color: white;
  border-radius: 25px;
  cursor: pointer;
  font-size: 1rem;
  font-weight: 500;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(25, 118, 210, 0.3);
}

.next-button:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(25, 118, 210, 0.4);
}

.next-button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

.scene-description {
  background: rgba(0, 0, 0, 0.4);
  border-radius: 20px;
  padding: 20px;
  backdrop-filter: blur(15px);
  border: 2px solid rgba(100, 181, 246, 0.3);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  max-height: 30vh;
  min-height: 200px;
}

.scene-description::before {
  content: '';
  position: absolute;
  top: -2px;
  left: -2px;
  right: -2px;
  bottom: -2px;
  background: linear-gradient(45deg, #64b5f6, #81c784, #ffb74d);
  border-radius: 22px;
  z-index: -1;
  opacity: 0.1;
}

.scene-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
}

.inspiration-top-left {
  position: absolute;
  top: 15px;
  left: 15px;
  z-index: 10;
  max-width: 120px;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 0px;
  margin-top: 35px;
  height: 80px;
  padding-bottom: 15px;
}

.card-header-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.card-header h3 {
  margin: 0 0 40px 0;
  font-size: 1.2rem;
  font-weight: 700;
  line-height: 1.2;
  color: #ffffff;
  text-shadow: 
    0 0 20px rgba(255, 204, 128, 0.8),
    0 0 40px rgba(255, 215, 0, 0.6),
    0 0 60px rgba(255, 107, 107, 0.4);
  background: linear-gradient(135deg, #ffcc80, #ffd700, #ff6b6b);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: titleGlow 4s ease-in-out infinite alternate;
  flex: 1;
  text-align: left;
  transition: all 0.3s ease;
  max-width: 70%;
}

@keyframes titleGlow {
  0% { 
    text-shadow: 
      0 0 20px rgba(255, 204, 128, 0.8),
      0 0 40px rgba(255, 215, 0, 0.6);
  }
  100% { 
    text-shadow: 
      0 0 30px rgba(255, 204, 128, 1),
      0 0 60px rgba(255, 215, 0, 0.8),
      0 0 80px rgba(255, 107, 107, 0.6);
  }
}

.card-tags-horizontal {
  display: flex;
  flex-direction: row;
  gap: 15px;
  align-items: center;
  justify-content: center;
  text-align: center;
  flex-wrap: wrap;
  margin-bottom: 0px;
}

.inspiration-tag {
  color: #ffd700;
  font-size: 0.65rem;
  font-weight: 500;
  font-style: italic;
  transition: all 0.3s ease;
  white-space: nowrap;
  line-height: 1.1;
  text-align: center;
  display: block;
  backdrop-filter: blur(5px);
}

.experience-type {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.3), rgba(118, 75, 162, 0.2));
  color: #a78bfa;
  padding: 6px 12px;
  border-radius: 15px;
  font-size: 0.75rem;
  font-weight: 600;
  border: 1px solid rgba(102, 126, 234, 0.4);
  box-shadow: 0 2px 8px rgba(102, 126, 234, 0.2);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
  transition: all 0.3s ease;
}

.creation-timestamp {
  background: linear-gradient(135deg, rgba(240, 147, 251, 0.3), rgba(207, 159, 255, 0.2));
  color: #e879f9;
  padding: 6px 12px;
  border-radius: 15px;
  font-size: 0.75rem;
  font-weight: 600;
  border: 1px solid rgba(240, 147, 251, 0.4);
  box-shadow: 0 2px 8px rgba(240, 147, 251, 0.2);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
  margin-top: 6px;
  transition: all 0.3s ease;
}

.experience-card:hover .inspiration-tag,
.experience-card:hover .experience-type,
.experience-card:hover .creation-timestamp {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(255, 204, 128, 0.4);
}

.experience-emoji {
  font-size: 1.5rem;
}


.scene-counter {
  font-size: 0.9rem;
  color: #81c784;
  font-weight: 500;
}

.generating-text {
  font-size: 0.9rem;
  color: #ffb74d;
  font-style: italic;
  animation: pulse 2s infinite;
}

.scene-text {
  font-size: 0.95rem;
  line-height: 1.5;
  color: #e0e6ed;
  margin: 0;
  font-weight: 400;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  font-family: 'Georgia', serif;
  word-wrap: break-word;
  hyphens: auto;
  overflow-y: auto;
  max-height: calc(30vh - 80px);
  padding-right: 10px;
}

.image-container {
  background: rgba(0, 0, 0, 0.3);
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  position: relative;
  overflow: hidden;
  border: 3px solid rgba(255, 255, 255, 0.2);
  box-shadow: 
    0 0 30px rgba(100, 181, 246, 0.2),
    inset 0 0 50px rgba(0, 0, 0, 0.3);
  min-height: 0;
}

.image-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.generated-image {
  max-width: 100%;
  max-height: 100%;
  width: auto;
  height: auto;
  object-fit: contain;
  border-radius: 15px;
  box-shadow: 
    0 10px 40px rgba(0, 0, 0, 0.5),
    0 0 20px rgba(100, 181, 246, 0.1);
  border: 2px solid rgba(255, 255, 255, 0.1);
}

.placeholder-overlay {
  position: absolute;
  top: 10px;
  right: 10px;
  background: rgba(0, 0, 0, 0.8);
  color: #ffb74d;
  padding: 8px 12px;
  border-radius: 8px;
  font-size: 0.8rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.placeholder-overlay small {
  font-size: 0.7rem;
  color: #90a4ae;
  text-align: center;
}

.image-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
  color: #b0bec5;
}

.loading-spinner {
  width: 50px;
  height: 50px;
  border: 3px solid rgba(255, 255, 255, 0.1);
  border-top: 3px solid #64b5f6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  width: 100%;
}

.placeholder-content {
  text-align: center;
  color: #90a4ae;
}

.placeholder-icon {
  font-size: 4rem;
  display: block;
  margin-bottom: 20px;
  opacity: 0.6;
}

.ambient-info {
  text-align: center;
  padding: 10px 15px;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 15px;
  border: 1px solid rgba(100, 181, 246, 0.2);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  flex-shrink: 0;
}

.ambient-text {
  font-size: 0.9rem;
  color: #90a4ae;
  font-style: italic;
}

@keyframes pulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* Responsive Design */
@media (max-width: 768px) {
  .observer-container {
    padding: 15px;
    gap: 15px;
  }
  
  .observer-header {
    flex-direction: column;
    gap: 15px;
    text-align: center;
  }
  
  .scene-description {
    padding: 20px;
  }
  
  .landing-title {
    font-size: 2.5rem;
  }
  
  .landing-content {
    padding: 30px 20px;
  }
}

/* Legacy styles for compatibility */
.speech-bubble {
  position: absolute;
  background: rgba(0, 20, 40, 0.95);
  color: #00ff88;
  padding: 12px 16px;
  border-radius: 20px;
  border: 2px solid #00ff88;
  max-width: 300px;
  font-size: 14px;
  line-height: 1.4;
  z-index: 1000;
  animation: fadeIn 0.3s ease-in;
  box-shadow: 0 0 20px rgba(0, 255, 136, 0.3);
}

.speech-bubble::after {
  content: '';
  position: absolute;
  bottom: -10px;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 10px solid transparent;
  border-right: 10px solid transparent;
  border-top: 10px solid #00ff88;
}

.speech-bubble.robot {
  background: rgba(40, 0, 20, 0.95);
  color: #ff6600;
  border-color: #ff6600;
  box-shadow: 0 0 20px rgba(255, 102, 0, 0.3);
}

.speech-bubble.robot::after {
  border-top-color: #ff6600;
}

.continue-button {
  background: none;
  border: 1px solid currentColor;
  color: inherit;
  padding: 4px 8px;
  margin-top: 8px;
  border-radius: 4px;
  cursor: pointer;
  font-family: inherit;
  font-size: 12px;
  transition: all 0.2s;
}

.continue-button:hover {
  background: currentColor;
  color: rgba(0, 20, 40, 0.95);
}

/* Business Metrics Overlay */
.business-metrics {
  position: absolute;
  top: 20px;
  right: 20px;
  background: rgba(0, 0, 0, 0.8);
  border: 2px solid #00ff88;
  border-radius: 10px;
  padding: 15px;
  color: #00ff88;
  font-family: 'Courier New', monospace;
  font-size: 14px;
  z-index: 100;
  min-width: 200px;
}

.business-metrics h3 {
  margin-bottom: 10px;
  color: #ffffff;
  text-align: center;
}

.metric-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 5px;
}

.metric-value {
  color: #ffff00;
  font-weight: bold;
}

@keyframes particleFloat {
  0%, 100% { opacity: 0.3; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.1); }
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

/* Model Attribution */
.model-attribution {
  position: fixed;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
  padding: 5px 15px;
  background: rgba(0, 0, 0, 0.7);
  border-radius: 10px;
  border: 1px solid rgba(100, 181, 246, 0.2);
  z-index: 1000;
}

.model-attribution p {
  margin: 0;
  font-size: 0.7rem;
  color: #90a4ae;
  opacity: 0.8;
}

/* Loading Screen */
.loading-screen {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #000;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #00ff88;
  z-index: 2000;
}

.loading-text {
  font-size: 24px;
  margin-bottom: 20px;
  animation: pulse 2s infinite;
}

.loading-bar {
  width: 300px;
  height: 4px;
  background: rgba(0, 255, 136, 0.2);
  border-radius: 2px;
  overflow: hidden;
}

.loading-progress {
  height: 100%;
  background: #00ff88;
  animation: loading 3s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

@keyframes loading {
  0% { width: 0%; }
  50% { width: 70%; }
  100% { width: 100%; }
}

/* Hampi Bazaar Theme Styles */
.hampi-theme {
  background: linear-gradient(135deg, #2d1810 0%, #8b4513 30%, #cd853f 70%, #daa520 100%);
}

.hampi-header {
  background: rgba(139, 69, 19, 0.4);
  border: 1px solid rgba(218, 165, 32, 0.3);
}

.hampi-header h2 {
  color: #daa520;
  text-shadow: 0 2px 4px rgba(139, 69, 19, 0.8);
}

.hampi-scene {
  background: rgba(139, 69, 19, 0.4);
  border: 2px solid rgba(218, 165, 32, 0.4);
  box-shadow: 0 8px 32px rgba(139, 69, 19, 0.4);
}

.hampi-scene::before {
  background: linear-gradient(45deg, #daa520, #cd853f, #b8860b);
}

.hampi-scene .scene-text {
  color: #f5deb3;
  text-shadow: 0 1px 2px rgba(139, 69, 19, 0.8);
}

.hampi-image {
  border: 3px solid rgba(218, 165, 32, 0.3);
  box-shadow: 
    0 0 30px rgba(218, 165, 32, 0.3),
    inset 0 0 50px rgba(139, 69, 19, 0.3);
}

.hampi-placeholder {
  color: #daa520;
}

.hampi-placeholder .placeholder-icon {
  color: #cd853f;
  text-shadow: 0 0 20px rgba(218, 165, 32, 0.5);
}

.hampi-button {
  background: linear-gradient(45deg, #b8860b, #daa520);
  box-shadow: 0 4px 15px rgba(218, 165, 32, 0.3);
}

.hampi-button:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(218, 165, 32, 0.4);
}

.hampi-info {
  background: rgba(139, 69, 19, 0.3);
  border: 1px solid rgba(218, 165, 32, 0.2);
}

.hampi-info .ambient-text {
  color: #daa520;
}

/* Image Loading States */
.image-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #90a4ae;
}

.image-loading p {
  margin-top: 20px;
  font-size: 1.1rem;
  color: #64b5f6;
}

.image-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #90a4ae;
  opacity: 0.7;
}

.image-placeholder p {
  margin-top: 20px;
  font-size: 1rem;
  text-align: center;
}

.loading-spinner {
  width: 50px;
  height: 50px;
  border: 4px solid rgba(100, 181, 246, 0.2);
  border-left: 4px solid #64b5f6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Try Latest Experience Styles */
.latest-experience-preview {
  text-align: center;
  margin: 20px 0;
}

.latest-experience-preview h3 {
  color: #ffd700;
  font-size: 1.5rem;
  margin-bottom: 15px;
}

.experience-description {
  color: #e2e8f0;
  font-size: 0.95rem;
  line-height: 1.6;
  margin-bottom: 15px;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

.experience-meta {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}

.content-type, .creation-date {
  background: rgba(255, 255, 255, 0.1);
  padding: 5px 12px;
  border-radius: 15px;
  font-size: 0.8rem;
  color: #cbd5e1;
}

.experience-loading {
  text-align: center;
  padding: 40px 20px;
}

.loading-spinner {
  width: 40px;
  height: 40px;
  border: 4px solid rgba(255, 215, 0, 0.3);
  border-top: 4px solid #ffd700;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 20px;
}

.experience-output {
  text-align: center;
  margin: 20px 0;
}

.experience-output h3 {
  color: #ffd700;
  font-size: 1.3rem;
  margin-bottom: 20px;
}

.generated-content {
  background: rgba(0, 0, 0, 0.3);
  border: 1px solid rgba(255, 215, 0, 0.3);
  border-radius: 15px;
  padding: 20px;
  margin: 20px auto;
  max-width: 600px;
  color: #e2e8f0;
  line-height: 1.6;
  font-size: 0.95rem;
}

.experience-actions {
  display: flex;
  gap: 15px;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 25px;
}
